# Postgres (Source)
PG_HOST=your localhost
PG_PORT=your port
PG_DATABASE=your database name
PG_USER=your username
PG_PASSWORD=your password

# Snowflake (Target)
SF_ACCOUNT=your account identifier
SF_USER=your username
SF_PASSWORD=your password
SF_WAREHOUSE=your warehouse name
SF_DATABASE=your database name
SF_SCHEMA=your schema name
SF_ROLE=your role name
